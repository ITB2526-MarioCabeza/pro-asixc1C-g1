# =====================================================================
# 1. SEGURIDAD DE AWS Y CLAVES PRIVADAS (¡LO MÁS CRÍTICO!)
# =====================================================================
# Bloquea las llaves SSH para que nadie las suba a internet por error
*.pem
*.key
*.pub
*.ppk

# Bloquea posibles archivos de credenciales locales de AWS
.aws/
credentials
amplify/

# =====================================================================
# 2. AUTOMATIZACIÓN (ANSIBLE Y ENTORNO)
# =====================================================================
# Archivos temporales o de reintento que genera Ansible
*.retry
*.log
.ansible/

# Archivos de variables sensibles si usáis contraseñas en texto plano
*secret*.yml
*vault*.yml

# =====================================================================
# 3. CONFIGURACIÓN DE EDITORES DE TEXTO (VS CODE / IDEs)
# =====================================================================
# Carpetas de configuración interna de vuestros editores locales
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# =====================================================================
# 4. ARCHIVOS BASURA DEL SISTEMA OPERATIVO
# =====================================================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# =====================================================================
# 5. TEMPORALES DE BASES DE DATOS (Por si editas scripts en local)
# =====================================================================
*.sql.bak
*.sql.old
